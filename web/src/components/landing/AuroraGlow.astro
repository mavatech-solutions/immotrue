{/*
  Simple, reliable soft glow behind the hero headline: a single
  radial-gradient div, sized with "closest-side" (fades to transparent
  exactly at the box edge on both axes, regardless of aspect ratio — no
  hard edges) and same-hue alpha stops (fading to the same color at 0
  alpha, not the `transparent` keyword, which is black at 0 alpha and
  would otherwise muddy the fade). No blur filter or mask layering —
  those introduced their own edge/tiling bugs without looking
  meaningfully better than a well-tuned gradient.
*/}
<div class="hero-glow"></div>

<style>
  .hero-glow {
    position: absolute;
    left: 50%;
    top: 22%;
    width: 130rem;
    height: 100rem;
    translate: -50% -50%;
    pointer-events: none;
    background: radial-gradient(
      ellipse closest-side,
      rgba(74, 127, 232, 0.22) 0%,
      rgba(74, 127, 232, 0.22) 15%,
      rgba(74, 127, 232, 0) 100%
    );
    animation: glow-pulse 10s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%,
    100% {
      opacity: 0.85;
    }
    50% {
      opacity: 1;
    }
  }
</style>
