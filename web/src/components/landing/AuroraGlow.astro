{/*
  Aurora-style glow, adapted from the well-known Aceternity UI "Aurora
  Background" pattern to our blue palette. The edge fade is a mask (pure
  black/transparent alpha), completely separate from the moving color layer
  (a blurred, animated repeating-linear-gradient) — masks composite via
  alpha multiplication only, so there's no RGB-toward-black interpolation
  bug and no box-edge/banding issues like a plain radial-gradient has.
*/}
<div class="aurora-glow"></div>

<style>
  .aurora-glow {
    position: absolute;
    left: 50%;
    top: 22%;
    width: 150rem;
    height: 115rem;
    translate: -50% -50%;
    overflow: hidden;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(ellipse 55% 50% at 50% 50%, black 25%, transparent 75%);
    mask-image: radial-gradient(ellipse 55% 50% at 50% 50%, black 25%, transparent 75%);
  }

  .aurora-glow::after {
    content: '';
    position: absolute;
    inset: -50%;
    background-image: repeating-linear-gradient(
      100deg,
      var(--color-accent-deep) 0%,
      var(--color-accent) 12%,
      var(--color-accent-luminous) 24%,
      var(--color-accent) 36%,
      var(--color-accent-deep) 48%
    );
    background-size: 200% 200%;
    filter: blur(60px);
    opacity: 0.28;
    animation: aurora-drift 25s linear infinite;
  }

  @keyframes aurora-drift {
    from {
      background-position: 0% 50%;
    }
    to {
      background-position: 200% 50%;
    }
  }
</style>
