{/*
  Soft glow behind the hero headline: a radial-gradient that fades to
  the page's own flat background color (var(--color-base)) instead of
  to alpha-transparent. Since the outer edge becomes literally the same
  color as the surrounding page, there's no boundary to see by
  construction — no alpha math, no `transparent`-keyword-interpolates-
  through-black bug, no masking/tiling risk. closest-side sizing still
  ensures the fade completes exactly at the box edge on both axes.
*/}
<div class="hero-glow"></div>

<style>
  .hero-glow {
    position: absolute;
    left: 50%;
    top: 22%;
    width: 130rem;
    height: 100rem;
    translate: -50% -50%;
    pointer-events: none;
    background: radial-gradient(
      ellipse closest-side,
      #16233d 0%,
      #16233d 15%,
      var(--color-base) 100%
    );
    animation: glow-pulse 10s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%,
    100% {
      opacity: 0.85;
    }
    50% {
      opacity: 1;
    }
  }
</style>
