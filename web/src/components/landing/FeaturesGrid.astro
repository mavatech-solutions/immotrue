---
const features = [
  { icon: '🎯', title: 'KI-Preisbewertung', description: 'Ampel-System zeigt sofort: fair oder überteuert' },
  { icon: '📊', title: 'Vollständiger KI-Bericht', description: 'Detaillierte Analyse mit Verhandlungsstrategie' },
  { icon: '💰', title: 'Finanzierungsrechner', description: 'Monatliche Rate, Break-Even, alles in Echtzeit' },
  { icon: '📍', title: 'Lage-Analyse', description: '12 Faktoren: ÖPNV, Schulen, Einkaufen, Ärzte' },
  { icon: '⚠️', title: 'Risiko-Erkennung', description: 'Versteckte Kosten und Risiken aufdecken' },
  { icon: '🔮', title: '10-Jahres Prognose', description: 'Wertentwicklung basierend auf echten Marktdaten' },
  { icon: '📂', title: 'Portfolio & Historie', description: 'Alle Analysen speichern und wiederkommen' },
  { icon: '🔔', title: 'Preisänderungs-Alarm', description: 'Push wenn dein Objekt günstiger wird' },
  { icon: '📄', title: 'PDF-Export', description: 'Professioneller Report für Bank und Notar' },
]
---

<section class="mx-auto max-w-6xl px-6 py-32">
  <h2 class="text-center font-display text-3xl md:text-4xl text-text-primary">
    Alles was du für deine Kaufentscheidung brauchst
  </h2>

  <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((feature, i) => (
      <div
        class="feature-card rounded-[20px] border border-border-subtle bg-surface p-6 hover:border-accent-luminous"
        style={`animation-delay: ${i * 100}ms;`}
      >
        <span class="text-2xl">{feature.icon}</span>
        <h3 class="mt-4 font-display text-lg text-text-primary">{feature.title}</h3>
        <p class="mt-2 font-body text-sm text-text-secondary">{feature.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  /*
    The scroll-in reveal (opacity/translateY) runs as a one-shot
    @keyframes animation with a per-card stagger delay, NOT a
    `transition`. Hover's lift and border-color get their own separate,
    delay-free `transition` — keeping these on two different
    mechanisms means the reveal's stagger delay can never bleed into
    the hover response (which it would if both were driven by the same
    `transition-delay`, since transform is used by both).
  */
  .feature-card {
    opacity: 0;
    transition:
      transform 200ms ease,
      border-color 200ms ease;
  }

  .feature-card.in-view {
    animation: fade-in-up 500ms ease-out both;
  }

  /*
    Once the reveal animation finishes, swap to this instead of leaving
    `.in-view` on: a running (or fill-forwards-completed) CSS animation
    keeps "winning" the `transform` property over regular rules like
    `:hover`, since animations take cascade priority regardless of
    specificity — so the hover lift would silently stop working once
    the reveal animation completed if `.in-view` just stayed applied.
  */
  .feature-card.revealed {
    opacity: 1;
  }

  .feature-card:hover {
    transform: translateY(-4px);
  }
</style>

<script>
  const cards = document.querySelectorAll('.feature-card');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const card = entry.target;
          card.classList.add('in-view');
          card.addEventListener(
            'animationend',
            () => {
              card.classList.remove('in-view');
              card.classList.add('revealed');
            },
            { once: true },
          );
          observer.unobserve(card);
        }
      }
    },
    { threshold: 0.2 },
  );
  cards.forEach((card) => observer.observe(card));
</script>
