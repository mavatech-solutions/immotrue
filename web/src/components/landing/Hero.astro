---
import UrlAnalyzer from './UrlAnalyzer';
import PortalsSection from './PortalsSection.astro';
import AuroraGlow from './AuroraGlow.astro';

// Small rising particles behind the headline — deterministic pseudo-random
// spread (no client JS needed) so the markup is identical on every render.
// Step of 41 is coprime with 100, so 14 particles don't land on repeat spots.
const particles = Array.from({ length: 14 }, (_, i) => ({
  left: (i * 41) % 100,
  size: 2 + (i % 3),
  duration: 10 + (i % 5) * 2,
  delay: -(i * 1.3).toFixed(1),
}));
---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-base px-6 py-32 text-center">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <AuroraGlow />

    {particles.map((p) => (
      <span
        class="absolute rounded-full bg-accent-luminous/70"
        style={`left:${p.left}%; bottom:-10px; width:${p.size}px; height:${p.size}px; animation: particle-rise ${p.duration}s linear infinite; animation-delay: ${p.delay}s;`}
      ></span>
    ))}
  </div>

  <div class="relative z-10 flex flex-col items-center gap-6">
    <p class="font-mono text-xs tracking-widest text-accent-luminous uppercase opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_both]">
      KI-Analyse für den DACH-Immobilienmarkt
    </p>

    <h1 class="max-w-3xl font-display text-5xl md:text-7xl leading-[1.1] text-text-primary opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_0.1s_both]">
      Jedes Inserat. <em class="italic text-accent-luminous">Analysiert in Sekunden.</em>
    </h1>

    <p class="max-w-xl font-body text-lg md:text-xl text-text-secondary opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_0.2s_both]">
      Preis, Lage und Rendite objektiv bewertet — bevor du eine €500.000-Entscheidung triffst.
    </p>

    <div id="analysieren" class="mt-2 w-full flex justify-center opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_0.3s_both]">
      <UrlAnalyzer client:load />
    </div>

    <p class="font-mono text-sm text-text-tertiary opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_0.4s_both]">
      ★★★★★ 4,8 · 10.000+ Nutzer in Deutschland, Österreich, der Schweiz
    </p>

    <div class="mt-8 w-full opacity-0 in-[.fonts-ready]:animate-[fade-in-up_0.8s_ease-out_0.5s_both]">
      <PortalsSection />
    </div>
  </div>
</section>
