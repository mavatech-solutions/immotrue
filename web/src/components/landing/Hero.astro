---
import UrlAnalyzer from './UrlAnalyzer';
import ResultPreviewCard from './ResultPreviewCard.astro';
---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-base px-6 py-32 text-center">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <span class="absolute left-[10%] top-[70%] h-64 w-64 rounded-full bg-accent/20 blur-3xl animate-[drift-up_18s_ease-in-out_infinite]"></span>
    <span class="absolute left-[70%] top-[80%] h-80 w-80 rounded-full bg-accent-luminous/15 blur-3xl animate-[drift-up_24s_ease-in-out_infinite_-6s]"></span>
    <span class="absolute left-[45%] top-[90%] h-56 w-56 rounded-full bg-accent-deep/25 blur-3xl animate-[drift-up_20s_ease-in-out_infinite_-12s]"></span>
  </div>

  <div class="relative z-10 flex flex-col items-center gap-6">
    <p class="font-mono text-xs tracking-widest text-accent-luminous uppercase animate-[fade-in-up_0.8s_ease-out]">
      KI-Analyse für den DACH-Immobilienmarkt
    </p>

    <h1 class="max-w-3xl font-display text-5xl md:text-7xl leading-[1.1] text-text-primary animate-[fade-in-up_0.8s_ease-out_0.1s_both]">
      Jedes Inserat. <em class="italic text-accent-luminous">Analysiert in Sekunden.</em>
    </h1>

    <p class="max-w-xl font-body text-lg md:text-xl text-text-secondary animate-[fade-in-up_0.8s_ease-out_0.2s_both]">
      Preis, Lage und Rendite objektiv bewertet — bevor du eine €500.000-Entscheidung triffst.
    </p>

    <div class="mt-2 w-full flex justify-center animate-[fade-in-up_0.8s_ease-out_0.3s_both]">
      <UrlAnalyzer client:load />
    </div>

    <p class="font-mono text-sm text-text-tertiary animate-[fade-in-up_0.8s_ease-out_0.4s_both]">
      ★★★★★ 4,8 · 10.000+ Nutzer in Deutschland, Österreich, der Schweiz
    </p>

    <div class="mt-8 flex justify-center animate-[fade-in-up_0.8s_ease-out_0.5s_both]">
      <ResultPreviewCard />
    </div>
  </div>
</section>
