---
import { getAllPortals } from '../../../../shared/utils/portalDetector';

// Reuses the same portal list the backend scrapers and the hero's
// live URL detection use — one source of truth, so this grid can't
// drift out of sync with what's actually supported (e.g. still
// listing a portal that's been discontinued, or one we've since added).
const portals = getAllPortals();

// No real portal logo assets (and using competitors' trademarked logos
// without permission would be a real legal risk) — a short monogram in
// our own brand style reads as "a logo grid" without borrowing anyone
// else's mark. Two letters from the first two words; for single-word
// camelCase brand names (ImmoScout24, not "Immo Scout24") prefer the
// next internal capital letter over just the second character, or
// "ImmoScout24" and "Immowelt" would both collide on "IM".
function monogram(name: string): string {
  const words = name.replace(/[^a-zA-Z0-9\s]/g, ' ').trim().split(/\s+/)
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase()
  const word = words[0]
  const nextCap = word.slice(1).match(/[A-Z]/)
  return (word[0] + (nextCap ? nextCap[0] : word[1])).toUpperCase()
}
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center">
  <h2 class="font-display text-3xl md:text-4xl text-text-primary">Alle wichtigen Portale — ein Tool</h2>

  <div class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-4">
    {portals.map((portal, i) => (
      <div class="portal-card group relative flex flex-col items-center gap-3 rounded-2xl border border-border-subtle bg-surface px-4 py-8" style={`animation-delay: ${i * 60}ms;`}>
        <span class="absolute right-3 top-3 text-base">{portal.flag}</span>
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-linear-to-br from-accent to-accent-luminous font-display text-lg text-on-accent transition-transform duration-300 group-hover:scale-105">
          {monogram(portal.name)}
        </div>
        <span class="font-body text-sm text-text-secondary">{portal.name}</span>
      </div>
    ))}
  </div>

  <p class="mt-8 font-body text-sm text-text-tertiary">Kein Portal dabei? Sag uns Bescheid.</p>
</section>

<style>
  /*
    Same pattern as FeaturesGrid: the reveal is a one-shot @keyframes
    animation (not a transition), swapped off to a plain "revealed"
    class once it finishes, so the completed animation doesn't keep
    "winning" the transform property over the :hover lift — a fill-
    forwards animation otherwise beats regular rules regardless of
    specificity.
  */
  .portal-card {
    opacity: 0;
    transition:
      transform 200ms ease,
      border-color 200ms ease;
  }

  .portal-card.in-view {
    animation: fade-in-up 500ms ease-out both;
  }

  .portal-card.revealed {
    opacity: 1;
  }

  .portal-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-luminous);
  }
</style>

<script>
  const cards = document.querySelectorAll('.portal-card');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const card = entry.target;
          card.classList.add('in-view');
          card.addEventListener(
            'animationend',
            () => {
              card.classList.remove('in-view');
              card.classList.add('revealed');
            },
            { once: true },
          );
          observer.unobserve(card);
        }
      }
    },
    { threshold: 0.2 },
  );
  cards.forEach((card) => observer.observe(card));
</script>
