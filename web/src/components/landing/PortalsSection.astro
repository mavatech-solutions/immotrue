---
import { Image } from 'astro:assets';
import { getAllPortals } from '../../../../shared/utils/portalDetector';
import immoscoutLogo from '../../assets/portals/immoscout.svg';
import immoweltLogo from '../../assets/portals/immowelt.svg';
import kleinanzeigenLogo from '../../assets/portals/kleinanzeigen.svg';
import ohnemaklerLogo from '../../assets/portals/ohnemakler.svg';
import willhabenLogo from '../../assets/portals/willhaben.svg';
import homegateLogo from '../../assets/portals/homegate.svg';

// Reuses the same portal list the backend scrapers and the hero's
// live URL detection use — one source of truth, so this strip can't
// drift out of sync with what's actually supported.
const portals = getAllPortals();

const logos: Record<string, ImageMetadata> = {
  immoscout: immoscoutLogo,
  immowelt: immoweltLogo,
  kleinanzeigen: kleinanzeigenLogo,
  ohnemakler: ohnemaklerLogo,
  willhaben: willhabenLogo,
  homegate: homegateLogo,
}

// Tripled (not just duplicated) so the -33.333% loop point is still
// covered by real content on very wide viewports — with only 6 logos,
// two copies could run out before the seam scrolls into view on an
// ultrawide monitor.
const track = [...portals, ...portals, ...portals]
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center">
  <h2 class="font-display text-3xl md:text-4xl text-text-primary">Alle wichtigen Portale — ein Tool</h2>

  <div class="marquee mt-12">
    <div class="marquee-track">
      {track.map((portal) => (
        <div class="flex h-14 shrink-0 items-center justify-center rounded-lg bg-white px-6 shadow-sm">
          <Image src={logos[portal.id]} alt={portal.name} width={160} height={40} class="h-6 w-auto object-contain" />
        </div>
      ))}
    </div>
  </div>

  <p class="mt-8 font-body text-sm text-text-tertiary">Kein Portal dabei? Sag uns Bescheid.</p>
</section>

<style>
  .marquee {
    overflow: hidden;
    /* Fades logos in/out at the edges instead of clipping them abruptly. */
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    gap: 2.5rem;
    animation: marquee-scroll 36s linear infinite;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* Track is 3 copies of the same content, so -33.333% is exactly
         one copy's width — the loop point lines up seamlessly. */
      transform: translateX(-33.3333%);
    }
  }
</style>
