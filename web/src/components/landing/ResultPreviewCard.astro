---
import Badge from '../ui/Badge.astro';
---

<div id="demo" class="w-full max-w-3xl rounded-3xl border border-border-subtle bg-surface p-6">
  <div class="flex items-start justify-between">
    <Badge variant="overpriced">Überteuert</Badge>
    <span class="font-body text-sm text-text-tertiary">ImmoScout24</span>
  </div>

  <p class="mt-6 font-mono text-4xl text-text-primary">€549.000</p>
  <p class="mt-1 font-mono text-sm text-verdict-overpriced">▲ 18% über Marktwert</p>

  <hr class="my-6 border-border-subtle" />

  <p class="text-center font-body text-xs text-text-tertiary">App Screenshot — Ergebnis-Screen</p>
</div>
