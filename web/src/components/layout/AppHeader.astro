---
import { Image } from 'astro:assets';
import ThemeToggle from '../ui/ThemeToggle.astro';
import LogoutButton from '../auth/LogoutButton';
import logo from '../../assets/logo_immotrue.png';
---

<header class="border-b border-border-subtle">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/dashboard" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-9 w-9" />
      ImmoTrue
    </a>
    <nav class="flex items-center gap-6">
      <a href="/portfolio" class="font-body text-sm text-text-secondary transition-colors duration-200 hover:text-text-primary">
        Portfolio
      </a>
      <a href="/alerts" class="font-body text-sm text-text-secondary transition-colors duration-200 hover:text-text-primary">
        Alarme
      </a>
      <a href="/analyse" class="font-body text-sm text-text-secondary transition-colors duration-200 hover:text-text-primary">
        Neue Analyse
      </a>
      <LogoutButton client:load />
      <ThemeToggle />
    </nav>
  </div>
</header>
