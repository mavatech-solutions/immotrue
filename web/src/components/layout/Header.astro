---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import logo from '../../assets/logo_immotrue.png';
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-8 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-12 w-12" />
      ImmoTrue
    </a>

    <nav class="hidden md:flex items-center gap-10 font-body text-sm text-text-secondary">
      <a href="#produkt" class="hover:text-text-primary transition-colors duration-200">Produkt</a>
      <a href="#preise" class="hover:text-text-primary transition-colors duration-200">Preise</a>
      <a href="#so-funktionierts" class="hover:text-text-primary transition-colors duration-200">So funktioniert's</a>
      <a href="#faq" class="hover:text-text-primary transition-colors duration-200">FAQ</a>
    </nav>

    <div class="flex items-center gap-5">
      <a href="/login" class="hidden sm:inline font-body text-sm text-text-secondary hover:text-text-primary transition-colors duration-200">Anmelden</a>
      <Button variant="primary" href="/login" class="px-5! py-2.5! hidden md:inline-flex text-sm">Kostenlos starten</Button>

      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="md:hidden text-text-primary"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="hidden md:hidden flex-col gap-1 border-t border-border-subtle bg-base px-8 py-4 font-body text-sm text-text-secondary">
    <a href="#produkt" class="py-2 hover:text-text-primary transition-colors duration-200">Produkt</a>
    <a href="#preise" class="py-2 hover:text-text-primary transition-colors duration-200">Preise</a>
    <a href="#so-funktionierts" class="py-2 hover:text-text-primary transition-colors duration-200">So funktioniert's</a>
    <a href="#faq" class="py-2 hover:text-text-primary transition-colors duration-200">FAQ</a>
    <a href="/login" class="py-2 hover:text-text-primary transition-colors duration-200">Anmelden</a>
    <Button variant="primary" href="/login" class="mt-2 w-full text-sm">Kostenlos starten</Button>
  </nav>
</header>

<style>
  /*
    Both states use explicit same-hue rgba(...) values (never the bare
    `transparent` keyword, which is rgba(0,0,0,0) and would interpolate
    the color channels toward black — the exact bug the hero glow had)
    and an explicit blur(...) baseline (never `none`, which can't be
    smoothly interpolated toward a real blur radius) so every property
    here transitions cleanly with no flash of an unstyled/default value.
    Using 0.01px rather than 0px because the build's CSS minifier
    collapses "blur(0px)" into the invalid "blur()" (no argument),
    which breaks the interpolation this whole approach depends on.
  */
  #site-header {
    background-color: rgba(10, 12, 11, 0);
    backdrop-filter: blur(0.01px);
    -webkit-backdrop-filter: blur(0.01px);
    border-bottom: 1px solid rgba(255, 255, 255, 0);
    transition:
      background-color 400ms ease,
      backdrop-filter 400ms ease,
      border-color 400ms ease;
  }

  #site-header.scrolled {
    background-color: rgba(10, 12, 11, 0.4);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const toggle = document.getElementById('mobile-nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('flex');
      mobileNav.classList.toggle('hidden', !isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileNav.classList.add('hidden');
        mobileNav.classList.remove('flex');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
