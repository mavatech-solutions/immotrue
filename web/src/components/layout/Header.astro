---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import logo from '../../assets/logo_immotrue.png';

const mobileLinks = [
  { href: '#produkt', label: 'Produkt' },
  { href: '#preise', label: 'Preise' },
  { href: '#so-funktionierts', label: "So funktioniert's" },
  { href: '#faq', label: 'FAQ' },
  { href: '/login', label: 'Anmelden' },
]
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-8 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-12 w-12" />
      ImmoTrue
    </a>

    <nav class="hidden md:flex items-center gap-10 font-body text-sm text-text-secondary">
      <a href="#produkt" class="hover:text-text-primary transition-colors duration-200">Produkt</a>
      <a href="#preise" class="hover:text-text-primary transition-colors duration-200">Preise</a>
      <a href="#so-funktionierts" class="hover:text-text-primary transition-colors duration-200">So funktioniert's</a>
      <a href="#faq" class="hover:text-text-primary transition-colors duration-200">FAQ</a>
    </nav>

    <div class="flex items-center gap-5">
      <a href="/login" class="hidden sm:inline font-body text-sm text-text-secondary hover:text-text-primary transition-colors duration-200">Anmelden</a>
      <div class="hidden md:block"><ThemeToggle /></div>
      <div class="hidden md:block"><Button variant="primary" href="/login" class="px-5! py-2.5! text-sm">Kostenlos starten</Button></div>

      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="hamburger relative z-10 md:hidden text-text-primary"
      >
        <span class="hamburger-line line-1"></span>
        <span class="hamburger-line line-2"></span>
        <span class="hamburger-line line-3"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-nav" class="mobile-nav md:hidden" aria-hidden="true">
  <nav class="mobile-nav-links">
    {mobileLinks.map((link, i) => (
      <a href={link.href} style={`--i:${i};`}>{link.label}</a>
    ))}
    <Button variant="primary" href="/login" class="mt-4 text-base" style={`--i:${mobileLinks.length};`}>
      Kostenlos starten
    </Button>
    <ThemeToggle class="mt-2" style={`--i:${mobileLinks.length + 1};`} />
  </nav>
</div>

<style>
  /*
    color-mix() with var(--color-base) rather than a hardcoded rgba(...)
    — makes the header's transparent-to-tinted transition automatically
    follow whichever theme is active, instead of always mixing toward
    the dark literal. Border stays constant at --color-border-subtle
    (already theme-aware and faint enough to not need its own
    transition) rather than animating between transparent and a color,
    which is where the hero glow's "interpolates through black" bug
    came from. An explicit blur(...) baseline (never `none`, which
    can't be smoothly interpolated toward a real blur radius) — using
    0.01px rather than 0px because the build's CSS minifier collapses
    "blur(0px)" into the invalid "blur()" (no argument), which breaks
    the interpolation this whole approach depends on.
  */
  #site-header {
    background-color: color-mix(in srgb, var(--color-base) 0%, transparent);
    backdrop-filter: blur(0.01px);
    -webkit-backdrop-filter: blur(0.01px);
    border-bottom: 1px solid var(--color-border-subtle);
    transition:
      background-color 400ms ease,
      backdrop-filter 400ms ease;
  }

  #site-header.scrolled {
    background-color: color-mix(in srgb, var(--color-base) 40%, transparent);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  /* Hamburger <-> X morph: three lines rotate/fade into a cross. */
  .hamburger {
    width: 24px;
    height: 16px;
  }

  .hamburger-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform 300ms ease,
      opacity 200ms ease,
      top 300ms ease;
  }

  .hamburger .line-1 {
    top: 0;
  }
  .hamburger .line-2 {
    top: 7px;
  }
  .hamburger .line-3 {
    top: 14px;
  }

  .hamburger.open .line-1 {
    top: 7px;
    transform: rotate(45deg);
  }
  .hamburger.open .line-2 {
    opacity: 0;
  }
  .hamburger.open .line-3 {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* Full-screen overlay menu, fades + blurs in rather than sliding —
     avoids needing a translate-based reveal to coexist with the
     per-link stagger animation on the same property. */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: color-mix(in srgb, var(--color-base) 0%, transparent);
    backdrop-filter: blur(0.01px);
    -webkit-backdrop-filter: blur(0.01px);
    opacity: 0;
    pointer-events: none;
    transition:
      background-color 300ms ease,
      backdrop-filter 300ms ease,
      opacity 300ms ease;
  }

  .mobile-nav.open {
    background-color: color-mix(in srgb, var(--color-base) 92%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .mobile-nav-links > * {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-text-primary);
    opacity: 0;
  }

  .mobile-nav.open .mobile-nav-links > * {
    animation: fade-in-up 500ms ease-out both;
    animation-delay: calc(var(--i) * 70ms + 100ms);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const toggle = document.getElementById('mobile-nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  if (toggle && mobileNav) {
    const setOpen = (open: boolean) => {
      toggle.classList.toggle('open', open);
      mobileNav.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
      mobileNav.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      setOpen(!mobileNav.classList.contains('open'));
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    // Clicking the dimmed backdrop itself (not the links) closes it too.
    mobileNav.addEventListener('click', (e) => {
      if (e.target === mobileNav) setOpen(false);
    });
  }
</script>
