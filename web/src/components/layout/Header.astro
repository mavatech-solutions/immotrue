---
import Button from '../ui/Button.astro';
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-colors duration-300">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2 font-display text-xl text-text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-luminous">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      ImmoTrue
    </a>

    <nav class="hidden md:flex items-center gap-8 font-body text-sm text-accent-luminous">
      <a href="#produkt" class="hover:text-text-primary transition-colors duration-200">Produkt</a>
      <a href="#preise" class="hover:text-text-primary transition-colors duration-200">Preise</a>
      <a href="#so-funktionierts" class="hover:text-text-primary transition-colors duration-200">So funktioniert's</a>
      <a href="#faq" class="hover:text-text-primary transition-colors duration-200">FAQ</a>
    </nav>

    <div class="flex items-center gap-6">
      <a href="/login" class="hidden sm:inline font-body text-sm text-text-secondary hover:text-text-primary transition-colors duration-200">Anmelden</a>
      <Button variant="primary" href="/login" class="px-5! py-2.5! text-sm">Kostenlos starten</Button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('bg-base/90', window.scrollY > 24);
      header.classList.toggle('backdrop-blur-md', window.scrollY > 24);
      header.classList.toggle('border-b', window.scrollY > 24);
      header.classList.toggle('border-border-subtle', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
