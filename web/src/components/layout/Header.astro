---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import logo from '../../assets/logo_immotrue.png';

const mobileLinks = [
  { href: '#produkt', label: 'Produkt' },
  { href: '#preise', label: 'Preise' },
  { href: '#so-funktionierts', label: "So funktioniert's" },
  { href: '#faq', label: 'FAQ' },
  { href: '/blog', label: 'Blog' },
  { href: '/login', label: 'Anmelden' },
]
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-8 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-12 w-12" />
      ImmoTrue
    </a>

    <nav class="hidden md:flex items-center gap-10 font-body text-sm text-text-secondary">
      <a href="#produkt" class="hover:text-text-primary transition-colors duration-200">Produkt</a>
      <a href="#preise" class="hover:text-text-primary transition-colors duration-200">Preise</a>
      <a href="#so-funktionierts" class="hover:text-text-primary transition-colors duration-200">So funktioniert's</a>
      <a href="#faq" class="hover:text-text-primary transition-colors duration-200">FAQ</a>
      <a href="/blog" class="hover:text-text-primary transition-colors duration-200">Blog</a>
    </nav>

    <div class="flex items-center gap-5">
      <a href="/login" class="hidden sm:inline font-body text-sm text-text-secondary hover:text-text-primary transition-colors duration-200">Anmelden</a>
      <div class="hidden md:block"><ThemeToggle /></div>
      <div class="hidden md:block"><Button variant="primary" href="/register" class="px-5! py-2.5! text-sm">Kostenlos starten</Button></div>

      <div class="md:hidden"><ThemeToggle /></div>

      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="hamburger relative z-10 md:hidden text-text-primary"
      >
        <span class="hamburger-line line-1"></span>
        <span class="hamburger-line line-2"></span>
        <span class="hamburger-line line-3"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-nav" class="mobile-nav md:hidden" aria-hidden="true">
  <nav class="mobile-nav-links">
    {mobileLinks.map((link, i) => (
      <a href={link.href} class="mobile-nav-link" style={`--i:${i};`}>{link.label}</a>
    ))}
    <Button variant="primary" href="/register" class="mt-4" style={`--i:${mobileLinks.length};`}>
      Kostenlos starten
    </Button>
  </nav>
</div>

<!-- #site-header/.hamburger*/.mobile-nav* styles live in global.css, not a
     scoped <style> block here — see the comment there for why. -->

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const toggle = document.getElementById('mobile-nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  if (toggle && mobileNav) {
    const setOpen = (open: boolean) => {
      toggle.classList.toggle('open', open);
      mobileNav.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
      mobileNav.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      setOpen(!mobileNav.classList.contains('open'));
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    // Clicking the dimmed backdrop itself (not the links) closes it too.
    mobileNav.addEventListener('click', (e) => {
      if (e.target === mobileNav) setOpen(false);
    });
  }
</script>
