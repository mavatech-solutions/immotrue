---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const { variant = 'primary', href, type = 'button', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-pill px-6 py-3 font-body font-medium text-sm transition-colors duration-200 disabled:opacity-40 disabled:pointer-events-none';

const variants = {
  primary: 'bg-linear-to-r from-accent to-accent-luminous text-base hover:from-accent-luminous hover:to-accent-luminous',
  secondary: 'border border-border-strong text-text-primary hover:border-accent-luminous',
  ghost: 'text-text-secondary hover:text-text-primary',
};

const classes = `${base} ${variants[variant]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag class={classes} href={href} type={href ? undefined : type}>
  <slot />
</Tag>
