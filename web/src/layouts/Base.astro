---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'KI-gestützte Immobilienanalyse für DACH.',
  ogType = 'website',
  ogImage,
  structuredData,
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <SEO title={title} description={description} type={ogType} image={ogImage} structuredData={structuredData} />
    <script is:inline>
      // Blocking + inline so this runs before first paint — anything
      // deferred would flash the default (dark) theme first for anyone
      // who has light stored, since the stylesheet already applied by
      // then reads html[data-theme] to pick colors.
      (function () {
        var stored = localStorage.getItem('theme');
        document.documentElement.setAttribute('data-theme', stored === 'light' ? 'light' : 'dark');
      })();
    </script>
  </head>
  <body class="bg-base text-text-primary font-body">
    <slot />
  </body>
</html>

<script>
  // Entrance animations wait for this — Playfair Display (fallback ->
  // real font swap) shifts the H1's layout noticeably given how
  // different its letter widths are from any fallback serif. Without
  // gating, that swap tends to land right around when the fade-in-up
  // animation finishes, looking like the animation itself "jumps".
  const markFontsReady = () => document.documentElement.classList.add('fonts-ready');
  if (document.fonts?.ready) {
    document.fonts.ready.then(markFontsReady);
  } else {
    markFontsReady();
  }
  // Safety net in case font loading stalls — don't leave content invisible forever.
  setTimeout(markFontsReady, 500);
</script>
