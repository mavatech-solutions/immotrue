---
import Landing from '../layouts/Landing.astro';
---

<Landing title="Seite nicht gefunden — ImmoTrue">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 pt-20 text-center">
    <p class="font-display text-6xl text-text-primary">404</p>
    <h1 class="font-display text-2xl text-text-primary">Diese Seite gibt es nicht (mehr)</h1>
    <p class="max-w-sm font-body text-text-secondary">
      Der Link könnte veraltet sein, oder du hast dich vertippt.
    </p>
    <a
      href="/"
      class="mt-4 inline-flex items-center justify-center rounded-pill bg-linear-to-r from-accent to-accent-luminous px-6 py-3 font-body text-sm font-medium text-on-accent transition-opacity duration-200 hover:opacity-90"
    >
      Zurück zur Startseite
    </a>
  </main>
</Landing>
