---
import { getCollection, render } from 'astro:content';
import Landing from '../../layouts/Landing.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const CATEGORY_LABELS: Record<string, string> = {
  guide: 'Ratgeber',
  market: 'Markt',
  legal: 'Recht',
  tips: 'Tipps',
};

const wordCount = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const tocHeadings = headings.filter((h) => h.depth <= 3);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    author: { '@type': 'Organization', name: post.data.author },
    publisher: { '@type': 'Organization', name: 'ImmoTrue' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://immotrue.de/blog' },
      {
        '@type': 'ListItem',
        position: 2,
        name: CATEGORY_LABELS[post.data.category],
        item: `https://immotrue.de/blog/category/${post.data.category}`,
      },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: `https://immotrue.de/blog/${post.id}` },
    ],
  },
];
---

<Landing
  title={post.data.seoTitle ?? `${post.data.title} — ImmoTrue Blog`}
  description={post.data.seoDescription ?? post.data.description}
  ogType="article"
  ogImage={`/og/${post.id}.png`}
  structuredData={structuredData}
>
  <main class="mx-auto max-w-6xl px-6 pt-32 pb-24">
    <a href="/blog" class="font-body text-sm text-text-secondary transition-colors duration-200 hover:text-text-primary">
      ← Zurück zum Blog
    </a>

    <header class="mt-6 max-w-3xl">
      <span class="font-mono text-xs tracking-wide text-accent-luminous uppercase">{CATEGORY_LABELS[post.data.category]}</span>
      <h1 class="mt-3 font-display text-4xl md:text-5xl text-text-primary">{post.data.title}</h1>
      <p class="mt-4 font-body text-sm text-text-tertiary">
        {post.data.author} · {post.data.pubDate.toLocaleDateString('de-DE')} · {readingMinutes} Min. Lesezeit
      </p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_240px]">
      <article class="prose-blog max-w-3xl font-body text-text-primary">
        <Content />
      </article>

      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24 rounded-3xl border border-border-subtle bg-surface-elevated p-5">
            <p class="font-display text-sm text-text-primary">Inhalt</p>
            <nav class="mt-3 flex flex-col gap-2">
              {tocHeadings.map((h) => (
                <a
                  href={`#${h.slug}`}
                  class="font-body text-sm text-text-secondary transition-colors duration-200 hover:text-accent-luminous"
                  style={`padding-left: ${(h.depth - tocHeadings[0].depth) * 0.75}rem`}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>

    <div class="mt-12 rounded-3xl border border-border-subtle bg-surface-elevated p-8 text-center">
      <p class="font-display text-xl text-text-primary">Bereit für deine eigene Analyse?</p>
      <a
        href="/analyse"
        class="mt-4 inline-flex items-center justify-center rounded-pill bg-linear-to-r from-accent to-accent-luminous px-6 py-3 font-body text-sm font-medium text-on-accent transition-opacity duration-200 hover:opacity-90"
      >
        Analysiere jetzt selbst
      </a>
    </div>

    {related.length > 0 && (
      <div class="mt-16">
        <h2 class="font-display text-xl text-text-primary">Verwandte Artikel</h2>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {related.map((p) => (
            <a
              href={`/blog/${p.id}`}
              class="flex flex-col gap-2 rounded-3xl border border-border-subtle bg-surface-elevated p-6 transition-colors duration-200 hover:border-accent-luminous"
            >
              <h3 class="font-display text-base text-text-primary">{p.data.title}</h3>
              <p class="font-body text-sm text-text-secondary">{p.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </main>
</Landing>

<style is:global>
  .prose-blog h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-blog p {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-blog ul,
  .prose-blog ol {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-blog li {
    margin-bottom: 0.4rem;
  }
  .prose-blog a {
    color: var(--color-accent-luminous);
  }
  .prose-blog strong {
    color: var(--color-text-primary);
  }
</style>
