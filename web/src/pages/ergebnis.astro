---
import Base from '../layouts/Base.astro';
import AppHeader from '../components/layout/AppHeader.astro';
import ResultScreen from '../components/analysis/ResultScreen';
---

<!-- Query-param page (?id=), not a dynamic /ergebnis/[id] route — the
     project has no SSR adapter configured yet (static output), and a
     dynamic path route needs prerender=false, which fails the build
     without one. RLS on `analyses` (auth.uid() = user_id) makes a
     direct client-side Supabase select safe, so no backend proxy is
     needed either. -->
<Base title="Analyse-Ergebnis — ImmoTrue">
  <AppHeader />
  <main class="mx-auto max-w-6xl px-6 py-16">
    <ResultScreen client:load />
  </main>
</Base>
