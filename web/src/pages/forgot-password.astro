---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ForgotPasswordForm from '../components/auth/ForgotPasswordForm';
import logo from '../assets/logo_immotrue.png';
---

<Base title="Passwort vergessen — ImmoTrue">
  <main class="flex min-h-screen flex-col items-center justify-center gap-8 px-6 py-16">
    <a href="/" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-9 w-9" />
      ImmoTrue
    </a>
    <h1 class="font-display text-2xl text-text-primary">Passwort vergessen?</h1>
    <ForgotPasswordForm client:load />
  </main>
</Base>
