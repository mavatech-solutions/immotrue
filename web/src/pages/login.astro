---
import Base from '../layouts/Base.astro';
---

<!-- Platzhalter — echter Login (Supabase Auth) kommt in Schritt 28 -->
<Base title="Anmelden — ImmoTrue">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 text-center">
    <h1 class="font-display text-3xl text-text-primary">Login kommt bald</h1>
    <p class="max-w-sm font-body text-text-secondary">
      Die Anmeldung wird in einem späteren Schritt gebaut. Bis dahin führt jeder Login-Link hierher.
    </p>
    <a href="/" class="font-body text-sm text-accent-luminous hover:text-text-primary transition-colors duration-200">
      Zurück zur Startseite
    </a>
  </main>
</Base>
