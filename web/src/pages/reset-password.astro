---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ResetPasswordForm from '../components/auth/ResetPasswordForm';
import logo from '../assets/logo_immotrue.png';
---

<!-- Not in the plan's explicit Schritt 28 file list, but required for the
     "Passwort vergessen" flow to actually work end-to-end — this is the
     redirect target resetPassword() points at, where the recovery-link
     session lets the user set a new password. -->
<Base title="Neues Passwort — ImmoTrue">
  <main class="flex min-h-screen flex-col items-center justify-center gap-8 px-6 py-16">
    <a href="/" class="flex items-center gap-2 font-display text-lg text-text-primary">
      <Image src={logo} alt="ImmoTrue" width={96} height={96} class="h-9 w-9" />
      ImmoTrue
    </a>
    <h1 class="font-display text-2xl text-text-primary">Neues Passwort festlegen</h1>
    <ResetPasswordForm client:load />
  </main>
</Base>
