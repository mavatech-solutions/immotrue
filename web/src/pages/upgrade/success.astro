---
import Base from '../../layouts/Base.astro';
import AppHeader from '../../components/layout/AppHeader.astro';
---

<!-- Stripe redirects here right after checkout, but the webhook that
     actually flips is_premium can arrive a moment later — this page
     doesn't try to read is_premium itself, it just confirms the payment
     was accepted and points to the dashboard. -->
<Base title="Willkommen bei Premium — ImmoTrue">
  <AppHeader />
  <main class="mx-auto flex max-w-2xl flex-col items-center gap-4 px-6 py-24 text-center">
    <span class="text-5xl">🎉</span>
    <h1 class="font-display text-2xl text-text-primary">Zahlung erfolgreich!</h1>
    <p class="font-body text-text-secondary">
      Dein Premium-Zugang wird gerade aktiviert — das dauert normalerweise nur wenige Sekunden.
    </p>
    <a
      href="/dashboard"
      class="mt-4 inline-flex items-center justify-center rounded-pill bg-linear-to-r from-accent to-accent-luminous px-6 py-3 font-body text-sm font-medium text-on-accent transition-opacity duration-200 hover:opacity-90"
    >
      Zum Dashboard
    </a>
  </main>
</Base>
